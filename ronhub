local alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
local tagname  = ""
for i = 1, 10 do
    local r = math.random(1, #alphabet)
    tagname = tagname .. alphabet:sub(r,r)
end

local function makeTag()
    local bb  = Instance.new("BillboardGui")
    bb.Name        = tagname
    bb.AlwaysOnTop = true
    bb.MaxDistance = 800
    bb.Size        = UDim2.new(0,140,0,42)
    local bg = Instance.new("Frame", bb)
    bg.Size                  = UDim2.new(1,0,1,0)
    bg.BackgroundColor3      = Color3.fromRGB(8,8,20)
    bg.BackgroundTransparency = 0.2
    bg.BorderSizePixel       = 0
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0,6)
    local bar = Instance.new("Frame", bg)
    bar.Size             = UDim2.new(0,3,1,0)
    bar.BackgroundColor3 = Color3.fromRGB(255,80,80)
    bar.BorderSizePixel  = 0
    local lbl = Instance.new("TextLabel", bg)
    lbl.Name                 = "Label"
    lbl.Size                 = UDim2.new(1,-8,0.55,0)
    lbl.Position             = UDim2.new(0,8,0,2)
    lbl.BackgroundTransparency = 1
    lbl.Font                 = Enum.Font.GothamBold
    lbl.TextSize             = 11
    lbl.TextColor3           = Color3.fromRGB(255,80,80)
    lbl.TextXAlignment       = Enum.TextXAlignment.Left
    lbl.Text                 = "..."
    local sub = Instance.new("TextLabel", bg)
    sub.Name                 = "Sub"
    sub.Size                 = UDim2.new(1,-8,0.4,0)
    sub.Position             = UDim2.new(0,8,0.58,0)
    sub.BackgroundTransparency = 1
    sub.Font                 = Enum.Font.Code
    sub.TextSize             = 9
    sub.TextColor3           = Color3.fromRGB(160,160,160)
    sub.TextXAlignment       = Enum.TextXAlignment.Left
    sub.Text                 = ""
    return bb
end
local templateTag = makeTag()

local function applyTag(unit)
    if unit:FindFirstChild(tagname) then return end
    local utype = safeGet(unit,"Type")
    local ucur  = safeGet(unit,"Current")
    local owner = safeGet(unit,"Owner")
    if not (utype and ucur and owner) then return end
    local isOwn   = owner.Value == player.Name
    local isEnemy = not isOwn
    if isEnemy and not state.showEnemy then return end
    local tag = templateTag:Clone()
    tag.Parent, tag.Adornee = unit, unit
    local lbl = tag:FindFirstChild("Label",true)
    local sub = tag:FindFirstChild("Sub",true)
    local bar = tag:FindFirstChildWhichIsA("Frame",true)  -- the accent bar
    if lbl then
        lbl.Text       = utype.Value
        lbl.TextColor3 = isOwn and Color3.fromRGB(80,255,130) or Color3.fromRGB(255,80,80)
    end
    if sub then sub.Text = fmt(ucur.Value).." troops" end
    -- tint bar
    local barFrame = tag:FindFirstChild("Frame",true) and tag:FindFirstChild("Frame",true):FindFirstChildWhichIsA("Frame")
    if barFrame then
        barFrame.BackgroundColor3 = isOwn and Color3.fromRGB(80,255,130) or Color3.fromRGB(255,80,80)
    end
end

local function refreshTag(unit)
    local tag  = unit:FindFirstChild(tagname)
    if not tag then return end
    local ucur = safeGet(unit,"Current")
    local sub  = tag:FindFirstChild("Sub",true)
    if ucur and sub then sub.Text = fmt(ucur.Value).." troops" end
end

local function clearTags()
    for _, u in ipairs(workspace.Units:GetChildren()) do
        local t = u:FindFirstChild(tagname)
        if t then t:Destroy() end
    end
end

workspace.Units.ChildAdded:Connect(function(child)
    if state.espOn then task.wait(0.6); applyTag(child) end
end)

