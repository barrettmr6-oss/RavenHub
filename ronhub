            task.delay(90,function() if S.puppetTargets[c] then pcall(function() gm.ManagePuppet:FireServer(c,"SendRequest") end) end end)
        end
    elseif a=="Puppet Accepted" then
        local c=b:gsub(" is now your puppet%.","")
        if c~=b then S.puppetTargets[c]=nil; notify("Puppet ✓",c.." puppet!","check-circle") end
