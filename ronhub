-- Alliance/Puppet event handler
gamemanager.AlertPopup.OnClientEvent:Connect(function(a, b)
    if type(b)~="string" then return end
    if a=="Alliance declined" then
        local c = b:gsub(" has refused to join our alliance!","")
        if c~=b and state.allyTargets[c] then
            log("Alliance declined by "..c..", retry in 60s")
            task.delay(60, function()
                if state.allyTargets[c] then
                    gamemanager.ManageAlliance:FireServer(c,"SendRequest")
                end
            end)
        end
    elseif a=="Alliance Accepted" then
        local c = b:gsub(" has accepted our offer of an alliance%.","")
        if c~=b then
            state.allyTargets[c]=nil
            notify("Alliance ✓", c.." accepted!", "check-circle")
            log(c.." accepted alliance")
        end
    elseif a=="Puppet declined" then
        local c = b:gsub(" has refused to become our puppet%.","")
        if c~=b and state.puppetTargets[c] then
            task.delay(90, function()
                if state.puppetTargets[c] then
                    pcall(function() gamemanager.ManagePuppet:FireServer(c,"SendRequest") end)
                end
            end)
        end
    elseif a=="Puppet Accepted" then
        local c = b:gsub(" is now your puppet%.","")
        if c~=b then
            state.puppetTargets[c]=nil
            notify("Puppet ✓", c.." is your puppet!", "check-circle")
        end
    end
end)

