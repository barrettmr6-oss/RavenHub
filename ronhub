    local function getPlayerTech(techId)
        -- Attempt to read tech level from game data
        local techFolder=safeGet(player,"Technologies") or safeGet(player,"Techs")
        if techFolder then
            local t=techFolder:FindFirstChild(techId)
            if t then return t.Value end
        end
        return 0
    end

    local function getCountryTech(countryName,techId)
        local base=safeGet(workspace,"Baseplate","Cities")
        if not base then return 0 end
        local folder=base:FindFirstChild(countryName)
        if not folder then return 0 end
        -- Try to find tech data on owner player
        for _,p in ipairs(Players:GetPlayers()) do
            local ls=safeGet(p,"leaderstats")
            if ls and ls:FindFirstChild("Country") and ls.Country.Value==countryName then
                local tf=safeGet(p,"Technologies") or safeGet(p,"Techs")
                if tf then
                    local t=tf:FindFirstChild(techId)
                    if t then return t.Value end
                end
            end
        end
        return 0
    end

    local function getCityCount(countryName)
        local base=safeGet(workspace,"Baseplate","Cities")
        if not base then return 0 end
        local folder=base:FindFirstChild(countryName)
        return folder and #folder:GetChildren() or 0
    end

    local function populateContent(countryName,tab)
        -- Clear content
        for _,c in ipairs(contentFrame:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end

        if tab=="Tech War Spy" then
            makeSection(contentFrame,"War Analysis: "..getCountry().." vs "..countryName, 1)
            local order=2
            for _,cat in ipairs(TECH_SPY_CATS) do
                local myTech=getPlayerTech(cat.id)
                local enemyTech=getCountryTech(countryName,cat.id)
                local advantage,advColor
                if myTech>enemyTech then
                    advantage="You"; advColor=Color3.fromRGB(80,220,120)
                elseif enemyTech>myTech then
                    advantage="Enemy"; advColor=Color3.fromRGB(255,80,80)
                else
                    advantage="Even"; advColor=Color3.fromRGB(180,180,180)
                end
