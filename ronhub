            local blds={}
            if city:FindFirstChild("Buildings") then
                for _, b in ipairs(city.Buildings:GetChildren()) do
                    table.insert(blds, b.Name)
                end
            end
            local res, rs=getResources(city),""
            for k,v in pairs(res) do if v>0 then rs=rs..k.."="..fmt(v).." " end end
            print(("║  [%s]"):format(city.Name))
            print(("║    Blds: %s"):format(#blds>0 and table.concat(blds,", ") or "none"))
            if rs~="" then print(("║    Res:  %s"):format(rs)) end
        end
        print("╚════════════════════════════════╝")
        notify("Dashboard",#cities.." cities printed","map")
    end
})

