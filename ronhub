-- ── Fmt ───────────────────────────────────────────────────────
local suffixes = {"K","M","B","T","Qa","Qi","Sx","Sp","Oc","No","Dc"}
local function fmt(n)
    n = tonumber(n) or 0
    for i = #suffixes,1,-1 do
        local v = 10^(i*3)
        if n >= v then return ("%.1f%s"):format(n/v,suffixes[i]) end
    end
    return tostring(math.floor(n))
end

local function safeGet(obj,...)
    local cur = obj
    for _,k in ipairs({...}) do if not cur then return nil end; cur=cur:FindFirstChild(k) end
    return cur
end

local function pcallFire(remote,...)
    local args={...}
    local ok,err=pcall(function() remote:FireServer(table.unpack(args)) end)
    if not ok then dbg("FireServer err: "..tostring(err)) end
end

local function getCountry()
    local ls=safeGet(player,"leaderstats")
    return ls and ls:FindFirstChild("Country") and ls.Country.Value or nil
end

local function getCities()
    local c=getCountry(); if not c then return {} end
    local f=safeGet(workspace,"Baseplate","Cities",c)
    return f and f:GetChildren() or {}
end

local function hasBuilding(city,name)
    return city:FindFirstChild("Buildings") and city.Buildings:FindFirstChild(name)~=nil
end

local function getResources(city)
    local res={}
    if city:FindFirstChild("Resources") then
        for _,r in ipairs(city.Resources:GetChildren()) do res[r.Name]=r.Value end
    end
    return res
end

local function allCountries()
    local list={}
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player then
            local ls=safeGet(p,"leaderstats")
            if ls and ls:FindFirstChild("Country") then table.insert(list,ls.Country.Value) end
        end
    end
    return list
end

local function getMyUnits()
    local list={}
    for _,u in ipairs(workspace.Units:GetChildren()) do
        local own=safeGet(u,"Owner")
        if own and own.Value==player.Name then table.insert(list,u) end
    end
    return list
end

local function getEnemyCities()
    local list={}
    local country=getCountry(); if not country then return list end
    local base=safeGet(workspace,"Baseplate","Cities"); if not base then return list end
    for _,folder in ipairs(base:GetChildren()) do
        if folder.Name~=country then
            for _,city in ipairs(folder:GetChildren()) do table.insert(list,city) end
        end
    end
    return list
end

local function getEnemyUnits()
    local list={}
    for _,u in ipairs(workspace.Units:GetChildren()) do
        local own=safeGet(u,"Owner")
        if own and own.Value~=player.Name then table.insert(list,u) end
    end
    return list
end

local function countryInGame(name)
    for _,p in ipairs(Players:GetPlayers()) do
        local ls=safeGet(p,"leaderstats")
        if ls and ls:FindFirstChild("Country") and ls.Country.Value==name then return true end
    end
    return false
end

