local function setProgress(pct, status)
    statusLabel.Text = status or statusLabel.Text
    pctLabel.Text = math.floor(pct) .. "%"
    TweenService:Create(barFill, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {
        Size = UDim2.new(pct / 100, 0, 1, 0)
    }):Play()
end

local function showToast(msg, color)
    toastLabel.Text = msg
    toastStroke.Color = color or Color3.fromRGB(80, 120, 255)
    local slideIn = TweenService:Create(toast, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -170, 1, -70)
    })
    slideIn:Play()
    task.delay(2.5, function()
        TweenService:Create(toast, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Position = UDim2.new(0.5, -170, 1, 20)
        }):Play()
    end)
end

