-- ============================================================
-- MAP LOADING LOGIC
-- ============================================================

local function collectAllParts()
    local parts = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation")
            or obj:IsA("SpecialMesh") or obj:IsA("Decal") or obj:IsA("Texture") then
            table.insert(parts, obj)
        end
    end
    return parts
end

local function preloadAll(parts)
    local total = #parts
    if total == 0 then return end

    local loaded = 0
    local batchSize = 20

    for i = 1, total, batchSize do
        local batch = {}
        for j = i, math.min(i + batchSize - 1, total) do
            table.insert(batch, parts[j])
        end

        ContentProvider:PreloadAsync(batch)
        loaded = loaded + #batch

        local pct = 30 + (loaded / total) * 60  -- 30–90%
        setProgress(pct, "Loading assets... (" .. loaded .. "/" .. total .. ")")
        task.wait()
    end
end

local function sweepLoadMap()
    -- Find map bounds
    local minPos = Vector3.new(math.huge, math.huge, math.huge)
    local maxPos = Vector3.new(-math.huge, -math.huge, -math.huge)

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local p = obj.Position
            minPos = Vector3.new(math.min(minPos.X, p.X), math.min(minPos.Y, p.Y), math.min(minPos.Z, p.Z))
            maxPos = Vector3.new(math.max(maxPos.X, p.X), math.max(maxPos.Y, p.Y), math.max(maxPos.Z, p.Z))
        end
    end

    local camera = workspace.CurrentCamera
    local prevCFrame = camera.CFrame
    local centerY = (minPos.Y + maxPos.Y) / 2 + 300

    local steps = 6
    local total = (steps + 1) * (steps + 1)
    local done = 0

    setProgress(10, "Scanning map boundaries...")
    showToast("📡  Scanning map... please wait")

    for i = 0, steps do
        for j = 0, steps do
            local x = minPos.X + (maxPos.X - minPos.X) * (i / steps)
            local z = minPos.Z + (maxPos.Z - minZ) * (j / steps)
            camera.CFrame = CFrame.new(Vector3.new(x, centerY, z), Vector3.new(x, centerY - 1, z))
            done = done + 1
            setProgress(10 + (done / total) * 20, "Sweeping map sector " .. done .. "/" .. total)
            task.wait(0.05)
        end
    end

    camera.CFrame = prevCFrame
end

