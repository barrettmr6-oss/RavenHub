task.spawn(function()
    task.wait(1)

    setProgress(0, "Starting up...")
    showToast("🚀  Map Loader activated!")
    task.wait(1)

    -- Step 1: Sweep
    sweepLoadMap()
    showToast("✅  Sweep complete!", Color3.fromRGB(80, 220, 120))
    task.wait(0.5)

    -- Step 2: Preload assets
    setProgress(30, "Collecting assets...")
    local parts = collectAllParts()
    showToast("📦  Found " .. #parts .. " assets to load")
    task.wait(0.5)

    preloadAll(parts)

    -- Step 3: Done!
    setProgress(100, "Map fully loaded!")
    showToast("🎉  Everything loaded!", Color3.fromRGB(80, 220, 120))

    -- Animate card out
    task.wait(1.5)
    TweenService:Create(card, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Position = UDim2.new(0.5, -240, 1.5, 0)
    }):Play()
    TweenService:Create(overlay, TweenInfo.new(0.5), {
        BackgroundTransparency = 1
    }):Play()
    task.wait(0.6)
    screenGui:Destroy()
end)
